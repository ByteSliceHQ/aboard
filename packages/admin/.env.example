# aboard admin — server-side environment.
# These are read by createServerFn handlers only; the token never reaches the browser.

# Origin of the aboard service.
ABOARD_URL=http://localhost:3000

# Base path the onboarding/admin API is mounted at.
BASE_PATH=/api/onboarding

# Admin bearer token. REQUIRED for any admin API call to succeed.
# Keep this secret — it is only ever used server-side.
ABOARD_ADMIN_TOKEN=
